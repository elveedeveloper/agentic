// src/lib/env.ts — Zod-validated env access.
// Import from here everywhere. Never read `process.env` outside this module.
import { z } from 'zod';

const Server = z.object({
  NODE_ENV: z.enum(['development', 'test', 'production']),
  DATABASE_URL: z.string().url(),
  // Add server-only vars here.
});

const Client = z.object({
  NEXT_PUBLIC_APP_URL: z.string().url(),
  // Anything client-facing must be prefixed NEXT_PUBLIC_.
  // Never put secrets here — they ship in the browser bundle.
});

const isServer = typeof window === 'undefined';

export const env = isServer
  ? { ...Server.parse(process.env), ...Client.parse(process.env) }
  : Client.parse({
      NEXT_PUBLIC_APP_URL: process.env.NEXT_PUBLIC_APP_URL,
    });
